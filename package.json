{
  "name": "erp-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "railway-build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start -p $PORT",
    "start:prod": "NODE_ENV=production node scripts/system-start.js || next start",
    "start:orchestrated": "node scripts/system-start.js || next start",
    "start:production": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:install": "playwright install chromium",
    "postinstall": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "seed:clean": "tsx prisma/seed-clean.ts",
    "db:reset": "tsx scripts/reset-database.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "export": "next build && next export",
    "serve": "next build && next start"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.14.0",
    "@tanstack/react-query": "^5.100.5",
    "@types/pdfkit": "^0.17.6",
    "autoprefixer": "^10.4.19",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "date-fns": "^3.6.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.378.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
