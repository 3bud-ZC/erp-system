  accountingPeriodId String?         // ADD THIS
  accountingPeriod AccountingPeriod? @relation(fields: [accountingPeriodId], references: [id]) // ADD THIS
  reversalEntryId String?            // ADD THIS
  reversalEntry   JournalEntry?      @relation("EntryReversal", fields: [reversalEntryId], references: [id]) // ADD THIS
  reversedBy      JournalEntry?      @relation("EntryReversal") // ADD THIS
  sourceEventId   String?            // ADD THIS
  correlationId   String?            // ADD THIS
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
