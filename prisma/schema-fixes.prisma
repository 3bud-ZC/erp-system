  @@index([referenceType])
  @@index([referenceId])
  @@index([tenantId])
}

// AFTER:
model JournalEntry {
  id              String             @id @default(cuid())
  entryNumber     String             @unique
  entryDate       DateTime
  description     String?
  referenceType   String?
  referenceId     String?
  totalDebit      Decimal            @default(0)
  totalCredit     Decimal            @default(0)
