// ============================================================================
// FIX 5: Add FiscalYear model (Referenced in AccountingPeriod but missing)
// ============================================================================

model FiscalYear {
  id          String             @id @default(cuid())
  name        String
  year        Int
  startDate   DateTime
  endDate     DateTime
  isClosed    Boolean            @default(false)
  closedAt    DateTime?
  closedBy    String?
  tenantId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  accountingPeriods AccountingPeriod[] // ADD THIS RELATION
  journalEntries JournalEntry[]     // ADD THIS RELATION
  tenant      Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year])
  @@index([tenantId])
  @@index([year])
}

// ============================================================================
// FIX 6: Add Outbox table for event-driven architecture (Outbox pattern)
// ============================================================================

model OutboxEvent {
  id            String   @id @default(cuid())
  eventType     String
  tenantId      String
  aggregateId   String
  aggregateType String
  version       Int
  data          Json
  metadata      Json
  status        String   @default("pending")
  occurredAt    DateTime
  processedAt   DateTime?
  retryCount    Int      @default(0)
  lastError     String?
  errorMessage  String?
  correlationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([eventType, status])
  @@index([aggregateId, eventType])
  @@index([occurredAt])
  @@index([processedAt])
}

