// ============================================================================
// FIX 1: Add tenantId to AccountingPeriod (CRITICAL - Multi-tenant violation)
// ============================================================================

// BEFORE:
model AccountingPeriod {
  id         String    @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     String    @default("open")
  fiscalYear Int
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([fiscalYear, name])
  @@index([status])
  @@index([fiscalYear])
}

// AFTER:
model AccountingPeriod {
  id         String    @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     String    @default("open")
  fiscalYear Int
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedBy   String?
  tenantId   String    // ADD THIS
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id]) // ADD THIS

  @@unique([fiscalYear, name])
  @@index([status])
  @@index([fiscalYear])
  @@index([tenantId]) // ADD THIS
}

