# =============================================================================
# ERP System — Environment Configuration Template
# Copy this file to `.env` and fill in real values for your environment.
# Never commit `.env` (already gitignored).
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway, Render, Supabase, local Postgres, ...)
# Example: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL=

# 32+ character random string (JWT signing). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 32+ character random string (NextAuth session cookie)
NEXTAUTH_SECRET=

# Public URL of the deployed app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Runtime environment: development | production | test
NODE_ENV=production

# ── Optional ────────────────────────────────────────────────────────────────

# Public API base URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Allow destructive seed/reset scripts to run (default: false in production).
# Set to `true` ONLY in disposable dev/staging databases.
ALLOW_SEED=false

# Bypass the auth-tier rate-limiter (5 req / 15 min). Used by Playwright in CI.
# MUST be 0 in any production deployment.
E2E_BYPASS_RATE_LIMIT=0

# Allow the E2E auth-reset helper (e2e/scripts/reset-admin-password.ts) to
# write to the admin user + E2E_DEFAULT tenant. Used only by CI / local E2E.
# MUST be unset (or 0) in any production deployment — the script will refuse.
E2E_ALLOW_AUTH_RESET=0

# Skip Next.js env-variable validation at build time
SKIP_ENV_VALIDATION=1

# Email Configuration (for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM="noreply@yourcompany.com"

# Optional: External Services
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=""

# Optional: Cloud Storage (AWS S3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""
